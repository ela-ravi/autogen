# =============================================================================
# Video Recap Agent — Backend Environment Variables
# =============================================================================
# Copy to .env and fill in your values
# For detailed documentation, see: backend/ENV_VARIABLES.md

# --- App Configuration ---
# DEBUG=true enables debug endpoints and detailed logging
# Set to true during development to access intermediate file downloads and enhanced logs
DEBUG=false
APP_NAME=Video Recap Agent
APP_VERSION=dev

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/video_recap

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Celery (Job Queue) ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- S3 / MinIO (Object Storage) ---
# For local development, uses MinIO (S3-compatible)
# For production, use AWS S3 or compatible service
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=video-recaps
S3_REGION=us-east-1
S3_PUBLIC_ENDPOINT=  # Optional: Public URL for presigned URLs (e.g., https://cdn.example.com)

# --- JWT Authentication ---
# JWT_SECRET: Change to a long random string in production (minimum 32 chars)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Google OAuth (optional) ---
# Leave empty to disable Google login
# Get credentials from: https://console.cloud.google.com
GOOGLE_CLIENT_ID=

# --- Stripe Billing (optional) ---
# Leave empty to disable billing features
# Get keys from: https://dashboard.stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# --- AI & Transcription ---
# OPENAI_API_KEY: Required for GPT-4o (recap generation) and TTS (narration)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
# WHISPER_MODEL_SIZE: tiny, base, small (default), medium, large
# Larger = more accurate but slower and uses more GPU memory
WHISPER_MODEL_SIZE=small

# --- Email & OTP (Resend) ---
# Optional: Only needed if email authentication is enabled
# Get API key from: https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=Video Recap <noreply@yourdomain.com>
OTP_EXPIRY_MINUTES=10

# --- CORS (Cross-Origin) ---
# List of allowed frontend origins for API calls
# Format: ["http://localhost:3000", "https://example.com"]
CORS_ORIGINS=["http://localhost:3000"]

# --- File Upload Limits ---
# Maximum file size for video uploads (bytes)
# Default: 2GB (2147483648)
# 1GB = 1073741824, 5GB = 5368709120
MAX_UPLOAD_SIZE_BYTES=2147483648

# --- Storage & Cleanup ---
# DELETE_INPUT_VIDEO_ON_COMPLETE: Delete original upload after successful processing
# - Input video is deleted after output + intermediates are stored in S3
# - Users can still download final output and intermediate files
# - Set to false to keep all files indefinitely (uses more storage)
DELETE_INPUT_VIDEO_ON_COMPLETE=true

# --- Feature Flags ---
# ENABLE_USER_API_KEYS: Allow users to provide their own OpenAI API key
# API_KEY_ALLOWED_EMAILS: List of emails allowed to use API keys ([] = all allowed)
# ENABLE_TRANSLATION: Enable multi-language translation feature
# ENABLE_BILLING: Enable Stripe billing (requires STRIPE_* keys above)
ENABLE_USER_API_KEYS=false
API_KEY_ALLOWED_EMAILS=[]
ENABLE_TRANSLATION=false
ENABLE_BILLING=false
BILLING_DISABLED_MESSAGE=Billing is not available yet. All features are currently free.
ENABLE_API_KEYS_MENU=true
